{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:6000"
      }
    }
  },
  "Proxy": {
    "TimeoutSeconds": 60,
    "HostnameSuffix": ".relay.local"
  },
  "Relay": {
    "// TenantsFile": "Path to tenants.json (preferred); if empty, falls back to the Tenants section below",
    "TenantsFile": "tenants.json",
    "// UsageStateFile": "Path to the persisted monthly-byte counter file (default: tenant-state.json)",
    "UsageStateFile": "tenant-state.json"
  },
  "Admin": {
    "// Password": "Required to access /_admin/* (and therefore the /admin/ Web UI). Leave empty to disable the admin API entirely",
    "Password": ""
  },
  "Tls": {
    "// Mode": "off | pfx | letsencrypt",
    "Mode": "off",
    "HttpsPort": 443,
    "RedirectHttpToHttps": false,
    "// PfxPath": "Path to a .pfx cert when Mode=pfx",
    "// PfxPassword": "Password for the .pfx (optional)",
    "LetsEncrypt": {
      "// Domains": "[ \"relay.example.com\", \"*.relay.example.com\" ] - DNS-01 needed for wildcards",
      "Domains": [],
      "EmailAddress": "",
      "StorePath": "letsencrypt",
      "UseStaging": false
    }
  },
  "Tenants": {
    "REPLACE-WITH-A-LONG-RANDOM-TOKEN": "alice"
  }
}
